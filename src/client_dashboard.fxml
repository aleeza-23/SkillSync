<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="500.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientController">

    <!-- TOP BAR -->
    <HBox layoutX="0" layoutY="0"
          prefWidth="600"
          prefHeight="60"
          spacing="15"
          style="-fx-background-color: #2c3e50; -fx-padding: 10;">

        <!-- Username -->
        <Label fx:id="topUsernameLabel"
               text="User"
               style="-fx-text-fill: white; -fx-font-size: 19px;" />

        <!-- Spacer (pushes items to right) -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Profile Icon (fake PFP) -->
        <Circle radius="18"
                style="-fx-fill: #ecf0f1;" />

        <!-- Logout Button -->
        <Button fx:id="logoutBtn"
                text="Logout"
                onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"

        />

    </HBox>

    <!-- Welcome Text -->
    <Label fx:id="welcomeLabel"
           layoutX="20"
           layoutY="90"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"
           text="Hello, User" />

    <!-- Main Buttons -->
    <VBox spacing="20"
          alignment="CENTER"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <Button fx:id="postJobBtn"
                text="Post Job"
                onAction="#handlePostJob"
                prefWidth="250" />

        <Button fx:id="myJobsBtn"
                text="My Jobs"
                onAction="#handleMyJobs"
                prefWidth="250" />

        <Button fx:id="applicationsBtn"
                text="Applications Received"
                prefWidth="250" />

    </VBox>

</AnchorPane>