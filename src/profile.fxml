<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ProfileController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;" spacing="10">
            <Label text="Edit Profile" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBack" style="-fx-padding: 8 20; -fx-font-size: 12;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ecf0f1;">
            <HBox spacing="30">
                <!-- Profile Picture Section -->
                <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-radius: 10; -fx-padding: 15; -fx-background-color: white;">
                    <Label text="Profile Picture:" style="-fx-font-weight: bold;"/>
                    <ImageView fx:id="profileImageView" fitHeight="150" fitWidth="150" preserveRatio="true"/>
                    <Button fx:id="uploadPictureButton" text="Upload Picture" onAction="#handleUploadPicture" style="-fx-padding: 8 15; -fx-font-size: 11;"/>
                    <Label fx:id="pictureStatusLabel" style="-fx-font-size: 10; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <!-- Profile Form Section -->
                <VBox spacing="15" style="-fx-border-color: #bdc3c7; -fx-border-radius: 10; -fx-padding: 20; -fx-background-color: white;" HBox.hgrow="ALWAYS">
                    <Label fx:id="usernameLabel" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    <Label fx:id="emailLabel" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    
                    <VBox spacing="5">
                        <Label text="Skills:" style="-fx-font-weight: bold;"/>
                        <TextArea fx:id="skillsTextArea" wrapText="true" prefRowCount="4" style="-fx-padding: 8; -fx-control-inner-background: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Experience:" style="-fx-font-weight: bold;"/>
                        <TextArea fx:id="experienceTextArea" wrapText="true" prefRowCount="5" style="-fx-padding: 8; -fx-control-inner-background: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 4;"/>
                    </VBox>

                    <Label fx:id="messageLabel" style="-fx-font-size: 12;"/>
                </VBox>
            </HBox>

            <!-- Action Buttons -->
            <HBox spacing="10">
                <Button fx:id="saveButton" text="Save Changes" onAction="#handleSave" style="-fx-padding: 10 30; -fx-font-size: 14;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
