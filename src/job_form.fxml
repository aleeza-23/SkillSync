<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="500.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="PostJobController">
    <children>

        <VBox alignment="CENTER" spacing="5.0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="30.0">
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2f3640;" text="SkillSync" />
            <Label style="-fx-font-size: 22px; -fx-font-weight: normal; -fx-text-fill: #2f3640;" text="Post a Job" />
        </VBox>

        <GridPane alignment="CENTER" hgap="15" vgap="15" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.topAnchor="120">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Columns -->
            <columnConstraints>
                <ColumnConstraints minWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <!-- Job Title -->
            <Label style="-fx-font-weight: bold;" text="Job Title:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="titleField" promptText="Enter job title" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <!-- Job Description -->
            <Label style="-fx-font-weight: bold; -fx-alignment: top-left;" text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextArea fx:id="descField" promptText="Enter detailed job description" wrapText="true" prefRowCount="4" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <!-- Budget -->
            <Label style="-fx-font-weight: bold;" text="Budget ($):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="budgetField" promptText="Enter budget amount" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <!-- Deadline -->
            <Label style="-fx-font-weight: bold;" text="Deadline:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <DatePicker fx:id="deadlinePicker" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <!-- Submit Button -->
            <Button text="Submit Job"
                    onAction="#handleSubmitJob"
                    style="-fx-background-color: #273c75; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15 8 15;"
                    GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4"
                    GridPane.halignment="CENTER" />

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>

    </children>
</AnchorPane>
