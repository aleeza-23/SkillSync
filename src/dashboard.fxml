<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="DashboardController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;" spacing="10">
            <Label text="SkillSync Dashboard" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" style="-fx-padding: 8 20; -fx-font-size: 12;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ecf0f1;">
            <HBox spacing="30">
                <!-- Profile Picture Section -->
                <VBox style="-fx-border-color: #bdc3c7; -fx-border-radius: 10; -fx-padding: 15; -fx-background-color: white;" prefWidth="150">
                    <ImageView fx:id="profileImageView" fitHeight="150" fitWidth="150" preserveRatio="true"/>
                </VBox>

                <!-- User Info Section -->
                <VBox spacing="15" style="-fx-border-color: #bdc3c7; -fx-border-radius: 10; -fx-padding: 20; -fx-background-color: white;" HBox.hgrow="ALWAYS">
                    <Label fx:id="usernameLabel" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    <Label fx:id="emailLabel" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    
                    <VBox spacing="5" style="-fx-border-top: 1 solid #ecf0f1; -fx-padding-top: 15;">
                        <Label text="Skills:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="skillsLabel" style="-fx-wrap-text: true;" wrapText="true"/>
                    </VBox>
                    
                    <VBox spacing="5" style="-fx-border-top: 1 solid #ecf0f1; -fx-padding-top: 15;">
                        <Label text="Experience:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="experienceLabel" style="-fx-wrap-text: true;" wrapText="true"/>
                    </VBox>
                </VBox>
            </HBox>

            <!-- Action Buttons -->
            <HBox spacing="10">
                <Button fx:id="editProfileButton" text="Edit Profile" onAction="#handleEditProfile" style="-fx-padding: 10 30; -fx-font-size: 14;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
